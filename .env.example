# Backend URL (Next.js server proxies /api/v1 to this host)
# Local: http://127.0.0.1:8080  |  Production (Render): https://backend-api-dcov.onrender.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase: enable GitHub provider; redirect URL = http://localhost:3000/auth/callback
# Backend: set SUPABASE_JWT_SECRET and AUTH_DISABLED=false for production auth
